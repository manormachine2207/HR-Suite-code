# Local development overrides for docker-compose dev stack
# Copy to `.env` (gitignored) to override defaults.
# Per BDR-007 (Container-First, 12-Factor), all secrets and environment-
# specific config come from env. Production/cluster values live in
# Kubernetes Secrets / ConfigMaps, not in this file.

# --- Postgres ---
# POSTGRES_PASSWORD=dev

# --- Backend (Spring Boot) ---
# The backend reads DB_URL / DB_USERNAME / DB_PASSWORD (12-Factor).
# In the compose stack these point at the postgres service; defaults are
# wired in docker-compose.yml. Override here only for non-default setups.
# DB_URL=jdbc:postgresql://postgres:5432/hrsuite
# DB_USERNAME=hrsuite
# OIDC_ISSUER_URI is intentionally UNSET in dev (the dev profile uses a
# mock JWT decoder). Set it in prod/staging to enable real OIDC.

# --- MinIO ---
# MINIO_ROOT_USER=hrsuite
# MINIO_ROOT_PASSWORD=devdevdev
