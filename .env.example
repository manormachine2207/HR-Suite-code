# Local development overrides for docker-compose dev stack
# Copy to `.env` (gitignored) to override defaults.
# Per BDR-007 (Container-First, 12-Factor), all secrets and environment-
# specific config come from env. Production/cluster values live in
# Kubernetes Secrets / ConfigMaps, not in this file.

# --- Postgres ---
# POSTGRES_PASSWORD=dev

# --- MinIO ---
# MINIO_ROOT_USER=hrsuite
# MINIO_ROOT_PASSWORD=devdevdev
